<%- include('../includes/header', {admin}) %>

  <div class="body-wrapper">
    <div class="container-fluid">
      <div class="card bg-info-subtle shadow-none position-relative overflow-hidden mb-4">
        <div class="card-body px-4 py-3">
          <div class="row align-items-center">
            <div class="col-md-8 col-sm-7">
              <h4 class="fw-semibold mb-1">Manage Newsletter</h4>

            </div>

            <div class="col-md-4 col-sm-5 text-md-end text-sm-start mt-3 mt-md-0 SellectAllDeletbtn">
              <%- include("../includes/button", { id: "bulkDeleteBtn" , type: "btn-outline-danger d-none" ,
                icon: "fa-solid fa-trash" , label: "Delete Selected" }) %>

            </div>
          </div>

        </div>
      </div>
      
      <div class="datatables">

        <div class="card">
          <div class="card-body">

            <div class="table-responsive">
              <table id="newsletterTable" class="table table-striped table-bordered text-nowrap align-middle">
                <thead>
                  <tr>
                    <th><input type="checkbox" id="selectAll"></th>
                    <th>Email</th>
                    <th>Date</th>
                    <th>Action</th>
                  </tr>
                </thead>
              </table>
            </div>
          </div>
        </div>


      </div>



    </div>
  </div>
  </div>

  <%- include('../includes/allscripts') %>
    <script src="/js/viewjs/newslatter.js"></script>
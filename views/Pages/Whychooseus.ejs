<%- include('../includes/header', {admin}) %>

    <div class="body-wrapper">
        <div class="container-fluid">
            <div class="card bg-info-subtle shadow-none position-relative overflow-hidden mb-4">
                <div class="card-body px-4 py-3">
                    <div class="row align-items-center">
                        <div class="col-md-8 col-sm-7">
                            <h4 class="fw-semibold mb-1">Manage Why Choose Us</h4>

                        </div>

                    </div>

                </div>
            </div>




            <div class="border rounded mt-3 p-4">
                <form id="whyChooseUsForm" enctype="multipart/form-data">

                    <div class="row g-3">
                        <div class="col-md-6">
                            <%- include("../includes/input", { label: "Label" , name: "badge" , id: "sectionBadge" ,
                                className: "form-control" , type: "text" , placeholder: "Why Choose Us" , required: true
                                }) %>
                        </div>

                        <!-- TITLE -->
                        <div class="col-md-6">
                            <%- include("../includes/input", { label: "Title" , name: "title" , id: "sectionTitle" ,
                                className: "form-control" , type: "text" , placeholder: "Why Choose Us" , required: true
                                }) %>
                                <small class="text-muted">
                  To highlight any word in the title, wrap it inside a <code>&lt;span&gt;</code>
                  <code>&lt;/span&gt;</code> tags.tag.
                </small>
                        </div>



                        <!-- DESCRIPTION -->
                        <div class="col-md-12">
                            <%- include("../includes/editorField", { label: "Description" , name: "description" ,
                                id: "description" , editorId: "editor" , aiBtnId: "generateAI" ,
                                aiBtnText: "Generate Description by AI" , showAIBtn: true, colClass: "col-md-12" ,
                                height: "200px" }) %>
                        </div>

                        <!-- FEATURES -->
                        <div class="col-md-12">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label fw-semibold">
                                    Why Choose Us Points <span class="text-danger">*</span>
                                </label>
                                <button type="button" id="addRowBtn" class="btn btn-sm btn-outline-primary">
                                    Add More
                                </button>
                            </div>

                            <!--  ONLY CONTAINER -->
                            <div id="rowsContainer"></div>
                        </div>

                        <!-- IMAGE -->
                        <div class="col-md-12">
                            <%- include("../includes/input", { label: "Image" , name: "image" , id: "imageInput" ,
                                className: "form-control" , type: "file" , required: false }) %>

                                <small class="text-muted d-block mt-1">
                                    <i class="fa-solid fa-circle-info text-primary"></i>
                                    Recommended Size:
                                    <strong>624 × 600 px</strong>,
                                    Formats:
                                    <strong>jpg | jpeg | png | webp</strong>
                                </small>

                                <div class="mt-3">
                                    <img id="previewImage" class="rounded border" style="display:none;width:160px;">
                                </div>
                        </div>

                    </div>

                    <div class="mt-4 text-start">
                        <%- include("../includes/button", { label: "Save Why Choose Us" , type: "btn-primary" ,
                            attr: 'type="submit"' }) %>
                    </div>

                </form>

            </div>





        </div>
    </div>

    <%- include('../includes/allscripts') %>
        <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

        <script src="/js/viewjs/whychooseus.js"></script>

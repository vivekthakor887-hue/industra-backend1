<%- include('../includes/header', {admin}) %>

<div class="body-wrapper">
  <div class="container-fluid">

    <!-- HEADER -->
    <div class="card bg-info-subtle shadow-none mb-4">
      <div class="card-body px-4 py-3">
        <h4 class="fw-semibold mb-0">Manage Seo Settings</h4>
      </div>
    </div>

    <!-- TABS -->
<div class="card">
  <div class="card-body">

    <div class="row">

      <!-- LEFT SIDE VERTICAL TABS -->
      <div class="col-md-3 border-end">
        <ul class="nav nav-pills flex-column gap-2" role="tablist">

          <li class="nav-item">
            <a class="nav-link active d-flex align-items-center"
               data-bs-toggle="tab"
               href="#seo-home"
               role="tab"
               data-type="home">
               <i class="fas fa-layer-group me-2"></i>
              Home
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link d-flex align-items-center"
               data-bs-toggle="tab"
               href="#seo-about"
               role="tab"
               data-type="about">
               <i class="fas fa-layer-group me-2"></i>
              About
            </a>
          </li>

            <li class="nav-item">
            <a class="nav-link d-flex align-items-center"
               data-bs-toggle="tab"
               href="#seo-services"
               role="tab"
               data-type="services">
               <i class="fas fa-layer-group me-2"></i>
              Services
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link d-flex align-items-center"
               data-bs-toggle="tab"
               href="#seo-projects"
               role="tab"
               data-type="projects">
               <i class="fas fa-layer-group me-2"></i>
              Projects
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link d-flex align-items-center"
               data-bs-toggle="tab"
               href="#seo-blog"
               role="tab"
               data-type="blog">
               <i class="fas fa-layer-group me-2"></i>
              Blog
            </a>
          </li>

             <li class="nav-item">
            <a class="nav-link d-flex align-items-center"
               data-bs-toggle="tab"
               href="#seo-contact"
               role="tab"
               data-type="contact">
             <i class="fas fa-layer-group me-2"></i>
              Contact
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link d-flex align-items-center"
               data-bs-toggle="tab"
               href="#seo-exhibition"
               role="tab"
               data-type="exhibition">
              <i class="fas fa-layer-group me-2"></i>
              Exhibition
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link d-flex align-items-center"
               data-bs-toggle="tab"
               href="#seo-catalogue"
               role="tab"
               data-type="catalogue">
             <i class="fas fa-layer-group me-2"></i>
              Catalogue
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link d-flex align-items-center"
               data-bs-toggle="tab"
               href="#seo-faq"
               role="tab"
               data-type="faq">
               <i class="fas fa-layer-group me-2"></i>
              FAQ
            </a>
          </li>

          
        </ul>
      </div>

      <!-- RIGHT SIDE TAB CONTENT -->
      <div class="col-md-9">
        <div class="tab-content ps-md-3">

          <% ['home','about','services','projects','blog','contact','exhibition','catalogue','faq'].forEach(page => { %>
          <div class="tab-pane fade <%= page === 'home' ? 'show active' : '' %>"
               id="seo-<%= page %>"
               role="tabpanel">

            <form class="seoForm" data-type="<%= page %>">
              <input type="hidden" name="type" value="<%= page %>">

              <div class="d-flex justify-content-between align-items-center mb-3">
                <label class="form-label fw-semibold mb-0"></label>
                <button type="button"
                        class="btn btn-sm btn-outline-primary generateSEO">
                  <i class="fa-solid fa-wand-magic-sparkles me-1"></i>
                  Generate AI SEO
                </button>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">
                  Meta Title <span class="text-danger">*</span>
                </label>
                <input type="text"
                       name="metaTitle"
                       class="form-control"
                       placeholder="Enter meta title"
                       required>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">
                  Meta Keywords <span class="text-danger">*</span>
                </label>
                <input type="text"
                       name="metaKeywords"
                       class="form-control"
                       placeholder="keyword1, keyword2"
                       required>
                <small class="text-muted">
                  Separate keywords by comma (,)
                </small>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">
                  Meta Description <span class="text-danger">*</span>
                </label>
                <textarea name="metaDescription"
                          rows="4"
                          class="form-control"
                          placeholder="Write meta description..."
                          required></textarea>
              </div>

              <button type="submit" class="btn btn-primary">
                Save / Update SEO
              </button>

            </form>
          </div>
          <% }) %>

        </div>
      </div>

    </div>
  </div>
</div>



  </div>
</div>

<%- include('../includes/allscripts') %>
<script src="/js/viewjs/seosetting.js"></script>

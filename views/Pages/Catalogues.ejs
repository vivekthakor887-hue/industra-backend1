<%- include('../includes/header', {admin}) %>

  <div class="body-wrapper">
    <div class="container-fluid">
      <div class="card bg-info-subtle shadow-none position-relative overflow-hidden mb-4">
        <div class="card-body px-4 py-3">
          <div class="row align-items-center">
            <div class="col-md-8 col-sm-7">
              <h4 class="fw-semibold mb-1">Manage Catalogues</h4>
            </div>
            <div class="col-md-4 col-sm-5 text-md-end text-sm-start mt-3 mt-md-0">
              <%- include("../includes/button", { id: "addCatalogueBtn" , type: "btn-primary" , icon: "fa-solid fa-plus"
                , label: "Add Catalogue" }) %>
            </div>
          </div>
        </div>
      </div>
                      <div class="card shadow-sm">
        <div class="card-body">

          <h4 class="mb-4">Update Catalogues Section</h4>

          <form id="sectionForm">

            <!-- TYPE (HIDDEN) -->
            <input type="hidden" name="type" value="<%= section ? section.type : 'faq' %>">

            <!-- LABEL + TITLE (ONE LINE) -->
            <div class="row mb-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Section Label<span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="label" value="<%= section ? section.label : '' %>"
                  placeholder="Home Page – Custom Section" required>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Title<span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="title" value="<%= section ? section.title : '' %>"
                  placeholder="Custom Subscriptions for Every Requirement" required>
                   <small class="text-muted">
  To highlight any word in the title, wrap it inside a <code>&lt;span&gt;</code>  <code>&lt;/span&gt;</code> tags.tag.
</small>
              </div>
               <div class="mb-4">
        <label class="form-label fw-semibold">Short Description<span class="text-danger">*</span></label>
        <textarea class="form-control" name="description" rows="3"
            placeholder="Write short description here..." required><%= section ? section.description : '' %></textarea>
    </div>

           <div class="col-md-12">
                <label class="form-label fw-semibold">Page Banner Background</label>
                <input type="file" class="form-control" name="pageBgBanner" id="pageBgBannerInput" accept="image/*">
                <small class="text-muted d-block mt-1">
                  <i class="fa-solid fa-circle-info text-primary"></i>
                  Recommended Size: <strong>1900 x 440 px</strong>, Formats:
                  <strong>/jpeg|jpg|png|webp/</strong>
                </small>
                <img id="pageBgBannerPreview" src="<%= section && section.pageBgBanner ? section.pageBgBanner : '' %>"
                  alt="Page Banner Background" class="img-thumbnail mt-2"
                  style="max-width: 200px; <%= section && section.pageBgBanner ? '' : 'display:none;' %>">
              </div>
            </div>

        

            <!-- BUTTON -->
            <button type="submit" class="btn btn-primary px-4">
              Update Section
            </button>

          </form>

        </div>
      </div>
      <div class="datatables">
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table id="zero_config" class="table table-striped table-bordered text-nowrap align-middle">
                <thead>
                  <tr>
                    <th>Title</th>
                    <th>Image</th>
                    <th>PDF</th>
                    <th class="action-col">Action</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Catalogue Modal -->
        <div class="modal fade" id="catalogueModal" tabindex="-1" aria-labelledby="catalogueModalLabel"
          aria-hidden="true">
          <div class="modal-dialog modal-md modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-3">

              <!-- Modal Header -->
              <div class="modal-header bg-light">
                <h5 class="modal-title fw-semibold" id="catalogueModalLabel">Add Catalogue</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>

              <!-- Modal Body -->
              <div class="modal-body p-4">
                <form id="catalogueForm" enctype="multipart/form-data">
                  <input type="hidden" id="catalogueId" name="id">

                  <div class="row g-3">

                    <!-- Catalogue Title -->
                    <div class="col-md-12">
                      <%- include('../includes/input', { label: "Catalogue Title" , name: "title" , id: "title" ,
                        className: "form-control" , type: "text" , placeholder: "Enter catalogue title" , required: true
                        }) %>
                    </div>

                    <!-- Catalogue Image -->
                    <div class="col-md-12">
                      <%- include('../includes/input', { label: "Catalogue Image" , name: "image" , id: "imageInput" ,
                        className: "form-control" , type: "file" , required: false }) %>
                        <div class="mt-3 text-center">
                          <img id="previewImage" src="" alt="Preview" class="rounded border"
                            style="display:none; width:140px; height:auto;">
                        </div>
                    </div>

                    <!-- Catalogue PDF -->
                    <div class="col-md-12">
                      <%- include('../includes/input', { label: "Catalogue PDF" , name: "pdf" , id: "pdfInput" ,
                        className: "form-control" , type: "file" , required: false, attr: 'accept="application/pdf"' })
                        %>
                        <div id="pdfPreview" class="mt-2 small text-muted" style="display:none;">
                          <i class="fa-solid fa-file-pdf text-danger me-1"></i>
                          <span id="pdfName"></span>
                        </div>
                    </div>

                  </div>
                </form>
              </div>

              <!-- Modal Footer -->
              <div class="modal-footer border-0 pt-0">
                <%- include("../includes/button", { label: "Cancel" , type: "btn-light" ,
                  attr: 'type="button" data-bs-dismiss="modal"' }) %>

                  <%- include("../includes/button", { label: "Save" , type: "btn-primary" ,
                    attr: 'type="submit" form="catalogueForm"' }) %>
              </div>

            </div>
          </div>
        </div>


      </div>
    </div>
  </div>
  </div>

  <%- include('../includes/allscripts') %>
    <script src="/js/viewjs/catalogues.js"></script>
      <script src="/js/viewjs/pagesection.js"></script>

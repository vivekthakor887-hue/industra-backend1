<%- include('../includes/header',{admin}) %>

      <div class="body-wrapper">
        <div class="container-fluid">
          <div class="card bg-info-subtle shadow-none position-relative overflow-hidden mb-4">
            <div class="card-body px-4 py-3">
         <div class="row align-items-center">
  <div class="col-md-8 col-sm-7">
    <h4 class="fw-semibold mb-1">Manage History</h4>
 
  </div>

  <div class="col-md-4 col-sm-5 text-md-end text-sm-start mt-3 mt-md-0">
    <%- include("../includes/button", { 
  id: "addHistoryBtn",
  type: "btn-primary",
  icon: "fa-solid fa-plus",
  label: "Add History"
}) %>
  </div>
</div>

            </div>
          </div>
                                     <div class="card shadow-sm">
        <div class="card-body">

          <h4 class="mb-4">Update History Section</h4>

          <form id="sectionForm">

            <!-- TYPE (HIDDEN) -->
            <input type="hidden" name="type" value="<%= section ? section.type : 'history' %>">

            <!-- LABEL + TITLE (ONE LINE) -->
            <div class="row mb-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Section Label<span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="label" value="<%= section ? section.label : '' %>"
                  placeholder="Home Page – Custom Section" required>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Title<span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="title" value="<%= section ? section.title : '' %>"
                  placeholder="Custom Subscriptions for Every Requirement" required>
                   <small class="text-muted">
  To highlight any word in the title, wrap it inside a <code>&lt;span&gt;</code>  <code>&lt;/span&gt;</code> tags.tag.
</small>
              </div>
               <div class="mb-4">
        <label class="form-label fw-semibold">Short Description<span class="text-danger">*</span></label>
        <textarea class="form-control" name="description" rows="3"
            placeholder="Write short description here..." required><%= section ? section.description : '' %></textarea>
    </div>
            </div>

           

            <!-- BUTTON -->
            <button type="submit" class="btn btn-primary px-4">
              Update Section
            </button>

          </form>

        </div>
      </div>
          <div class="datatables">
         
      
    <div class="card">
      <div class="card-body">
        <div class="table-responsive">
          <table id="zero_config" class="table table-striped table-bordered text-nowrap align-middle">
            <thead>
              <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Image</th>
                <th>Year</th>

                <th class="action-col">Action</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

<!-- History Modal -->
<div class="modal fade" id="historyModal" tabindex="-1" aria-labelledby="historyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg rounded-3">

      <!-- Header -->
      <div class="modal-header bg-light-subtle text-white">
        <h5 class="modal-title fw-semibold" id="historyModalLabel">Add History</h5>
        <button type="button" class="btn-close btn-close-dark" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <!-- Body -->
      <div class="modal-body p-4">
        <form id="historyForm" enctype="multipart/form-data">
          <input type="hidden" id="historyId" name="id">

          <div class="row g-3">
            <!-- Title -->
            <div class="col-md-12">
              <label for="title" class="form-label fw-medium">Title <span class="text-danger">*</span></label>
              <input type="text" id="title" name="title" class="form-control" placeholder="Enter history title" required>
            </div>

 <!-- Description + Generate by AI -->
        <div class="col-md-12">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <label class="form-label fw-semibold mb-0 text-dark">
      Description
    </label>
    <button type="button" id="generateAiBtn" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1   px-3 py-1">
      <i class="fa-solid fa-wand-magic-sparkles"></i>
      <span>Generate Description by AI</span>
    </button>
  </div>

  <div id="editor" class="border rounded-3 shadow-sm" style="height: 200px;"></div>
  <input type="hidden" id="description" name="description">
</div>


            <!-- Image + Year on same line -->
            <div class="col-md-6">
              <label class="form-label fw-medium">History Image</label>
              <input type="file" id="imageInput" name="image" class="form-control">
                <small class="text-muted d-block mt-1">
                          <i class="fa-solid fa-circle-info text-primary"></i>
                          Recommended Size: <strong>192 x 192 px</strong>, Formats:
                          <strong>/jpeg|jpg|png|webp/</strong>
                        </small>
              <div class="mt-3 text-center">
                <img id="previewImage" src="" alt="Preview" class="rounded border"
                  style="display:none; width:140px; height:auto;">
              </div>
            </div>

            <div class="col-md-6 d-flex flex-column justify-content-between">
              <div>
                <label class="form-label fw-medium">Year</label>
                <input type="number" id="year" name="year" class="form-control" placeholder="e.g., 2024" min="1900" max="2100">
              </div>
              <small class="text-muted mt-2">Enter the historical year</small>
            </div>
          </div>
        </form>
      </div>

      <!-- Footer -->
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" form="historyForm" class="btn btn-primary px-4">Save</button>
      </div>
    </div>
  </div>
</div>


  </div>
        
         
           
          </div>
        </div>
      </div>

     <%- include('../includes/allscripts') %>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script src="/js/viewjs/history.js"></script>
    <script src="/js/viewjs/pagesection.js"></script>

<%- include('../includes/header', {admin}) %>

    <div class="body-wrapper">
        <div class="container-fluid">
            <div class="card bg-info-subtle shadow-none position-relative overflow-hidden mb-4">
                <div class="card-body px-4 py-3">
                    <div class="row align-items-center">
                        <div class="col-md-8 col-sm-7">
                            <h4 class="fw-semibold mb-1">ManageFaq</h4>

                        </div>


                        <div class="col-md-4 col-sm-5 text-md-end text-sm-start mt-3 mt-md-0">
                            <button class="btn btn-primary px-4" id="addFaqBtn">
                                <i class="fa-solid fa-plus me-2"></i> Add FAQ
                            </button>
                        </div>
                    </div>

                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body">

                    <h4 class="mb-4">Update Faq Section</h4>

                    <form id="sectionForm">

                        <!-- TYPE (HIDDEN) -->
                        <input type="hidden" name="type" value="<%= section ? section.type : 'faq' %>">

                        <!-- LABEL + TITLE (ONE LINE) -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Section Label<span
                                        class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="label"
                                    value="<%= section ? section.label : '' %>" placeholder="Home Page – Custom Section"
                                    required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Title<span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="title"
                                    value="<%= section ? section.title : '' %>"
                                    placeholder="Custom Subscriptions for Every Requirement" required>
                                     <small class="text-muted">
  To highlight any word in the title, wrap it inside a <code>&lt;span&gt;</code>  <code>&lt;/span&gt;</code> tags.tag.
</small>
                            </div>
                             <div class="mb-4">
        <label class="form-label fw-semibold">Short Description<span class="text-danger">*</span></label>
        <textarea class="form-control" name="description" rows="3"
            placeholder="Write short description here..." required><%= section ? section.description : '' %></textarea>
    </div>
          <div class="col-md-12">
                <label class="form-label fw-semibold">Page Banner Background</label>
                <input type="file" class="form-control" name="pageBgBanner" id="pageBgBannerInput" accept="image/*">
                <small class="text-muted d-block mt-1">
                  <i class="fa-solid fa-circle-info text-primary"></i>
                  Recommended Size: <strong>1900 x 440 px</strong>, Formats:
                  <strong>/jpeg|jpg|png|webp/</strong>
                </small>
                <img id="pageBgBannerPreview" src="<%= section && section.pageBgBanner ? section.pageBgBanner : '' %>"
                  alt="Page Banner Background" class="img-thumbnail mt-2"
                  style="max-width: 200px; <%= section && section.pageBgBanner ? '' : 'display:none;' %>">
              </div>
                        </div>



                        <!-- BUTTON -->
                        <button type="submit" class="btn btn-primary px-4">
                            Update Section
                        </button>

                    </form>

                </div>
            </div>
            <div class="datatables">


                <div class="card">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="zero_config" class="table table-striped table-bordered text-nowrap align-middle">
                                <thead>
                                    <tr>
                                        <th>Question</th>
                                        <th class="action-col">Action</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- FAQ Modal -->
                <div class="modal fade" id="faqModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-md modal-dialog-top">
                        <div class="modal-content border-0 shadow-lg rounded-3">

                            <div class="modal-header bg-light-subtle">
                                <h5 class="modal-title fw-semibold" id="faqModalLabel">Add FAQ</h5>
                                <button type="button" class="btn-close btn-close-dark" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body p-4">
                                <form id="faqForm">

                                    <input type="hidden" id="faqId" name="id">

                                    <div class="row g-3">

                                        <div class="col-md-12">
                                            <%- include("../includes/input", { label: "Question" , name: "question" ,
                                                id: "question" , placeholder: "Enter FAQ question" , required: true })
                                                %>

                                        </div>
                                        <div class="col-md-12">
                                            <div class="d-flex justify-content-end">
                                                <button type="button" id="generateAiBtn"
                                                    class="btn btn-sm btn-primary mt-4">
                                                    Generate Answer
                                                </button>
                                            </div>
                                            <div class="d-flex align-items-start gap-2">

                                                <!-- Textarea takes majority of space -->
                                                <div class="flex-grow-1">
                                                    <%- include("../includes/textarea", { label: "Answer" ,
                                                        name: "answer" , id: "answer" , rows: 4,
                                                        placeholder: "Enter FAQ answer" , required: true }) %>
                                                </div>


                                            </div>
                                        </div>


                                    </div>

                                </form>
                            </div>

                            <div class="modal-footer border-0 pt-0">
                                <%- include("../includes/button", { label: "Cancel" , type: "btn-light" ,
                                    attr: 'type="button" data-bs-dismiss="modal"' }) %>

                                    <%- include("../includes/button", { label: "Save" , type: "btn-primary px-4" ,
                                        attr: 'type="submit" form="faqForm"' }) %>
                            </div>

                        </div>
                    </div>
                </div>


            </div>



        </div>
    </div>
    </div>

    <%- include('../includes/allscripts') %>
        <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
        <script src="/js/viewjs/faq.js"></script>
          <script src="/js/viewjs/pagesection.js"></script>

<%- include('../includes/header', {admin}) %>
  <% const sectionsMap={}; section.forEach(sec=> {
    sectionsMap[sec.sectionType] = sec;
    });

    const sectionList = section; // for sidebar + tabs
    %>

    <div class="body-wrapper">
      <div class="container-fluid">

        <!-- PAGE HEADER -->
        <div class="card bg-info-subtle shadow-none mb-4">
          <div class="card-body px-4 py-3">
            <h4 class="fw-semibold mb-0">Section Settings</h4>
          </div>
        </div>

        <div class="row">

          <!-- LEFT SIDEBAR -->
          <div class="col-md-3">
            <div class="card h-100 shadow-sm">
              <div class="card-body p-3">
                <h5 class="text-center text-primary fw-semibold mb-3">
                  Sections
                </h5>

                <div class="nav flex-column nav-pills" role="tablist">
                  <% sectionList.forEach((sec, index)=> { %>
                    <a class="nav-link mb-2 <%= index === 0 ? 'active' : '' %>" data-bs-toggle="pill"
                      href="#<%= sec.sectionType %>">
                      <i class="fas fa-layer-group me-2"></i>
                      <%= sec.sectionType.charAt(0).toUpperCase() + sec.sectionType.slice(1) %>
                    </a>
                    <% }) %>
                </div>

              </div>
            </div>
          </div>

          <!-- RIGHT CONTENT -->
          <div class="col-md-9">
            <div class="tab-content">

              <% sectionList.forEach((sec, index)=> { %>
                <div class="tab-pane fade <%= index === 0 ? 'show active' : '' %>" id="<%= sec.sectionType %>">

                  <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                      <%= sec.sectionType.charAt(0).toUpperCase() + sec.sectionType.slice(1) %> Menu Management
                    </div>

                    <div class="table-responsive">
                      <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <% if(sec.sectionType==='header' || sec.sectionType==='home' || sec.sectionType==="about" )
                              { %>
                              <th style="width:40px"></th>
                              <% } %>

                                <th>Section Name</th>
                                <% if(sec.sectionType==='header' ) { %>
                                  <th>updated section name</th>
                                  <% } %>

                                    <th class="text-center">Visible</th>
                                         <% if(sec.sectionType==='header' ) { %>
                                  <th class="text-center">Visible Footer</th>
                                  <% } %>
                          </tr>
                        </thead>
                        <tbody>
                          <% (sec.items || []) .sort((a,b)=>a.display_order-b.display_order)
                            .forEach(item => { %>
                            <tr data-key="<%= item.section_key %>">
                              <% if(sec.sectionType==='header' || sec.sectionType==='home' || sec.sectionType==="about"
                                ) { %>
                                <td class="text-muted">
                                  <i class="fas fa-grip-vertical"></i>
                                </td>
                                <% } %>


                                  <td>
                                    <%= item.section_name %>
                                  </td>


                                  <% if(sec.sectionType==='header' ) { %>

                                    <td>
                                      <input type="text" class="form-control form-control-sm section-name-input"
                                        value="<%= item.updated_section_name || item.section_name %>">
                                    </td>
                                    <% } %>

                                      <!-- hidden input inside a td -->
                                      <td style="display:none;">
                                        <input type="hidden" class="section-key" value="<%= item.section_key %>">
                                        <input type="hidden" class="original-section-name" value="<%= item.section_name %>">

                                      </td>

                                      <td class="text-center">
                                        <input type="checkbox" class="form-check-input is_visible" <%=item.is_visible ? 'checked'
                                          : '' %>>
                                      </td>
                                       <% if(sec.sectionType==='header' ) { %>
                                      
                                        <td class="text-center">
                                           <% if(item.section_key=='getquote' || item.section_key=='search' || item.section_key=='sidebar') { %>

                                        <input style="display:none;" type="checkbox" class="form-check-input is_visible_footer" <%=item.is_visible_footer ? 'checked'
                                          : '' %>>
                                         <% }else{ %>
                                             <input type="checkbox" class="form-check-input is_visible_footer" <%=item.is_visible_footer ? 'checked'
                                          : '' %>>
                                         <% } %>

                                      </td>
                                         <% } %>
                            </tr>
                            <% }) %>
                        </tbody>

                      </table>
                    </div>

                    <div class="card-footer text-start">
                      <button class="btn btn-primary">
                        Save Changes
                      </button>
                    </div>
                  </div>

                </div>
                <% }) %>

            </div>
          </div>

        </div>


      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <%- include('../includes/allscripts') %>
      <script src="/js/viewjs/sectionsetting.js"></script>
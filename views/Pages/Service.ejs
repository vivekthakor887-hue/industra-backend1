<%- include('../includes/header', {admin}) %>

  <div class="body-wrapper">
    <div class="container-fluid">
      <div class="card bg-info-subtle shadow-none position-relative overflow-hidden mb-4">
        <div class="card-body px-4 py-3">
          <div class="row align-items-center">
            <div class="col-md-8 col-sm-7">
              <h4 class="fw-semibold mb-1">Manage Services</h4>
            </div>
            <div class="col-md-4 col-sm-5 text-md-end">
              <%- include("../includes/button", { id: "openServiceModal" , type: "btn-primary" ,
                icon: "fa-solid fa-plus" , label: "Add Service" }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">

          <h4 class="mb-4">Update Services Section</h4>

          <form id="sectionForm">

            <!-- TYPE (HIDDEN) -->
            <input type="hidden" name="type" value="<%= section ? section.type : 'faq' %>">

            <!-- LABEL + TITLE (ONE LINE) -->
            <div class="row mb-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Section Label<span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="label" value="<%= section ? section.label : '' %>"
                  placeholder="Home Page – Custom Section" required>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Title<span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="title" value="<%= section ? section.title : '' %>"
                  placeholder="Custom Subscriptions for Every Requirement" required>
                <small class="text-muted">
                  To highlight any word in the title, wrap it inside a <code>&lt;span&gt;</code>
                  <code>&lt;/span&gt;</code> tags.tag.
                </small>
              </div>
              <div class="mb-4">
                <label class="form-label fw-semibold">Short Description<span class="text-danger">*</span></label>
                <textarea class="form-control" name="description" rows="3" placeholder="Write short description here..."
                  required><%= section ? section.description : '' %></textarea>
              </div>

       <!-- Main Image -->
<div class="col-md-6">
  <label class="form-label fw-semibold">Services Section Background Image</label>
  <input 
    type="file" 
    class="form-control" 
    name="image" 
    id="imageInput" 
    accept="image/*"
  >
  <small class="text-muted d-block mt-1">
    <i class="fa-solid fa-circle-info text-primary"></i>
    Recommended Size: <strong>1920 x 850 px</strong>, Formats:
    <strong>/jpeg|jpg|png|webp/</strong>
  </small>
  <img 
    id="imagePreview" 
    src="<%= section && section.image ? section.image : '' %>" 
    alt="Section Image"
    class="img-thumbnail mt-2"
    style="max-width: 200px; <%= section && section.image ? '' : 'display:none;' %>"
  >
</div>

<div class="col-md-6">
  <label class="form-label fw-semibold">Page Banner Background</label>
  <input 
    type="file" 
    class="form-control" 
    name="pageBgBanner" 
    id="pageBgBannerInput" 
    accept="image/*"
  >
  <small class="text-muted d-block mt-1">
    <i class="fa-solid fa-circle-info text-primary"></i>
    Recommended Size: <strong>1900 x 440 px</strong>, Formats:
    <strong>/jpeg|jpg|png|webp/</strong>
  </small>
  <img 
    id="pageBgBannerPreview" 
    src="<%= section && section.pageBgBanner ? section.pageBgBanner : '' %>" 
    alt="Page Banner Background"
    class="img-thumbnail mt-2"
    style="max-width: 200px; <%= section && section.pageBgBanner ? '' : 'display:none;' %>"
  >
</div>
            </div>


            <!-- BUTTON -->
            <button type="submit" class="btn btn-primary px-4">
              Update Section
            </button>

          </form>

        </div>
      </div>
      <div class="datatables">
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table id="zero_config" class="table table-striped table-bordered text-nowrap align-middle">
                <thead>
                  <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Image</th>
                    <th class="action-col">Action</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Service Modal -->
      <div class="modal fade" id="serviceModal" tabindex="-1" aria-labelledby="serviceModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
          <div class="modal-content border-0 shadow-lg rounded-3">

            <!-- Header -->
            <div class="modal-header bg-light-subtle">
              <h5 class="modal-title fw-semibold" id="serviceModalLabel">Add Service</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body p-4">
              <form id="serviceForm" enctype="multipart/form-data">
                <input type="hidden" id="serviceId" name="id">

                <div class="row g-3">
                  <!-- Service Title (INPUT COMPONENT) -->
                  <div class="col-md-12">
                    <%- include("../includes/input", { label: "Service Title" , name: "title" , id: "title" ,
                      type: "text" , placeholder: "Enter service title" , required: true }) %>
                  </div>

                  <!-- Description + AI Button (EDITOR COMPONENT) -->
                  <%- include("../includes/editorField", { label: "Description" , name: "description" ,
                    id: "description" , editorId: "serviceEditor" , aiBtnId: "generateServiceDescBtn" ,
                    aiBtnText: "Generate Description by AI" , showAIBtn: true, colClass: "col-md-12" , height: "200px"
                    }) %>

                    <div class="col-md-12">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label fw-semibold">
                          Why Choose Us Points <span class="text-danger">*</span>
                        </label>
                        <button type="button" id="addRowBtn" class="btn btn-sm btn-outline-primary">
                          Add More
                        </button>
                      </div>

                      <!--  ONLY CONTAINER -->
                      <div id="rowsContainer"></div>
                    </div>

                    <!-- Service Image (INPUT component with preview handled in JS) -->
                    <div class="col-md-12">
                      <%- include("../includes/input", { label: "Service Image" , name: "image" ,
                        id: "serviceImageInput" , type: "file" , className: "" , required: false }) %>

                        <small class="text-muted d-block mt-1">
                          <i class="fa-solid fa-circle-info text-primary"></i>
                          Recommended Size: <strong>1000 x 1142 px</strong>, Formats:
                          <strong>/jpeg|jpg|png|webp/</strong>
                        </small>
                        <div class="mt-3">
                          <img id="servicePreviewImage" src="" class="rounded border"
                            style="display:none; width:140px; height:auto;">
                        </div>
                    </div>

                </div>
              </form>
            </div>

            <!-- Footer Buttons -->
            <div class="modal-footer border-0 pt-0">
              <%- include("../includes/button", { label: "Cancel" , type: "btn-light" ,
                attr: 'type="button" data-bs-dismiss="modal"' }) %>

                <%- include("../includes/button", { label: "Save" , type: "btn-primary px-4" ,
                  attr: 'type="submit" form="serviceForm"' }) %>
            </div>

          </div>
        </div>
      </div>
      <!-- /Service Modal -->

    </div>
  </div>

  <%- include('../includes/allscripts') %>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="/js/viewjs/service.js"></script>
    <script src="/js/viewjs/pagesection.js"></script>
<%- include('../includes/header', {admin}) %>

<div class="body-wrapper">
  <div class="container-fluid">

    <!-- Header Section -->
    <div class="card bg-info-subtle shadow-none position-relative overflow-hidden mb-4">
      <div class="card-body px-4 py-3">
        <div class="row align-items-center">
          <div class="col-md-8 col-sm-7">
            <h4 class="fw-semibold mb-1">Manage Hero Section</h4>
          </div>
          <div class="col-md-4 col-sm-5 text-md-end text-sm-start mt-3 mt-md-0">
            <button id="addHeroBtn" class="btn btn-primary px-4">
              <i class="fa-solid fa-plus me-2"></i> Add Hero
            </button>
          </div>
        </div>
      </div>
    </div>

<!-- Table Section -->
<div class="datatables">
  <div class="card">
    <div class="card-body">
      <div class="table-responsive">
        <table id="heroTable" class="table table-striped table-bordered align-middle">
          <thead>
            <tr>
              <th>Media</th>
              <th>Label</th> <!-- ADDED LABEL COLUMN -->
              <th>Title</th>
              <th>Description</th>
              <th class="action-col">Action</th>
            </tr>
          </thead>
        </table>
      </div>
    </div>
  </div>

  <!-- MODAL -->
  <div class="modal fade" id="heroModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <form id="heroForm" enctype="multipart/form-data">
          <input type="hidden" id="heroId" name="id">

          <div class="modal-header">
            <h5 class="modal-title">Hero Section</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <div class="modal-body">
            
            <!-- ADDED LABEL INPUT -->
            <div class="mb-3">
              <label class="form-label">Label</label>
              <input type="text" name="label" id="label" class="form-control" placeholder="e.g. New Arrival">
            </div>

            <div class="mb-3">
              <label class="form-label">Title <span class="text-danger">*</span></label>
              <input type="text" name="title" id="title" class="form-control" required>
                <small class="text-muted">
  To highlight any word in the title, wrap it inside a <code>&lt;span&gt;</code>  <code>&lt;/span&gt;</code> tags.tag.
</small>
            </div>

            <div class="mb-3">
              <label class="form-label">Description <span class="text-danger">*</span></label>
              <textarea name="description" id="description" class="form-control" rows="3" required></textarea>
            </div>

            <div class="mb-3">
              <label class="form-label">Media <span class="text-danger">*</span></label>
              <input type="file" name="image" id="mediaInput" class="form-control" accept="image/*,video/*"> 
                <small class="text-muted d-block mt-1">
                          <i class="fa-solid fa-circle-info text-primary"></i>
                          Recommended Size: <strong>1920 x 850 px</strong>, Formats:
                          <strong>/jpeg|jpg|png|webp/mp4 max upload size 50MB for video</strong>
                        </small>
              <img id="previewImg" class="mt-2 rounded" style="max-width:120px; display:none;">
              <video id="previewVideo" class="mt-2 rounded" style="max-width:200px; display:none;" controls></video>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
  </div>
</div>

<%- include('../includes/allscripts') %>
<script src="/js/viewjs/herosection.js"></script>

<%- include('../includes/header', {admin}) %>

  <div class="body-wrapper">
    <div class="container-fluid">
      <div class="card bg-info-subtle shadow-none position-relative overflow-hidden mb-4">
        <div class="card-body px-4 py-3">
          <div class="row align-items-center">
            <div class="col-md-8 col-sm-7">
              <h4 class="fw-semibold mb-1">Manage Project</h4>
            </div>
            <div class="col-md-4 col-sm-5 text-md-end">
              <%- include("../includes/button", { id: "openProductModal" , type: "btn-primary" ,
                icon: "fa-solid fa-plus" , label: "Add Project" }) %>
            </div>
          </div>
        </div>
      </div>
      <div class="card shadow-sm">
        <div class="card-body">

          <h4 class="mb-4">Update Project Section</h4>

          <form id="sectionForm">

            <!-- TYPE (HIDDEN) -->
            <input type="hidden" name="type" value="<%= section ? section.type : 'faq' %>">

            <!-- LABEL + TITLE (ONE LINE) -->
            <div class="row mb-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Section Label<span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="label" value="<%= section ? section.label : '' %>"
                  placeholder="Home Page – Custom Section" required>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Title<span class="text-danger">*</span></label>
                <input type="text" class="form-control" name="title" value="<%= section ? section.title : '' %>"
                  placeholder="Custom Subscriptions for Every Requirement" required>
                <small class="text-muted">
                  To highlight any word in the title, wrap it inside a <code>&lt;span&gt;</code>
                  <code>&lt;/span&gt;</code> tags.tag.
                </small>
              </div>
              <div class="mb-4">
                <label class="form-label fw-semibold">Short Description<span class="text-danger">*</span></label>
                <textarea class="form-control" name="description" rows="3" placeholder="Write short description here..."
                  required><%= section ? section.description : '' %></textarea>
              </div>
              <div class="col-md-12">
                <label class="form-label fw-semibold">Page Banner Background</label>
                <input type="file" class="form-control" name="pageBgBanner" id="pageBgBannerInput" accept="image/*">
                <small class="text-muted d-block mt-1">
                  <i class="fa-solid fa-circle-info text-primary"></i>
                  Recommended Size: <strong>1900 x 440 px</strong>, Formats:
                  <strong>/jpeg|jpg|png|webp/</strong>
                </small>
                <img id="pageBgBannerPreview" src="<%= section && section.pageBgBanner ? section.pageBgBanner : '' %>"
                  alt="Page Banner Background" class="img-thumbnail mt-2"
                  style="max-width: 200px; <%= section && section.pageBgBanner ? '' : 'display:none;' %>">
              </div>
            </div>



            <!-- BUTTON -->
            <button type="submit" class="btn btn-primary px-4">
              Update Section
            </button>

          </form>

        </div>
      </div>
      <div class="datatables">
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table id="zero_config" class="table table-striped table-bordered text-nowrap align-middle">
                <thead>
                  <!-- Corrected Order of Table Headers -->
                  <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Image</th>
                    <th class="action-col">Action</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Modal -->

      <div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
          <div class="modal-content border-0 shadow-lg rounded-3">

            <!-- Header -->
            <div class="modal-header bg-light-subtle">
              <h5 class="modal-title fw-semibold" id="productModalLabel">Add Project</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body p-4">
              <form id="productForm" enctype="multipart/form-data">
                <input type="hidden" id="productId" name="id">
                <div class="row g-3">

                  <!-- Category -->
                  <div class="col-md-12">
                    <%- include("../includes/select", { label: "Select Category" , name: "category" , id: "category" ,
                      options: [], required: true, className: "form-select" , colClass: "col-md-12" }) %>
                  </div>

                  <!-- Product Title -->
                  <div class="col-md-12">
                    <%- include("../includes/input", { label: "Project Title" , name: "title" , id: "title" ,
                      type: "text" , placeholder: "Enter product title" , required: true }) %>
                  </div>

                  <div class="col-md-6">
                    <%- include("../includes/input", { label: "Name" , name: "name" , id: "name" , type: "text" ,
                      placeholder: "Enter name" , required: false }) %>
                  </div>
                  <div class="col-md-6">
                    <%- include("../includes/input", { label: "About" , name: "about" , id: "about" , type: "text" ,
                      placeholder: "Short about text" , required: false }) %>
                  </div>
                  <!-- Description + AI -->
                  <%- include("../includes/editorField", { label: "Description" , name: "description" ,
                    id: "description" , editorId: "editor" , aiBtnId: "generateDescBtn" ,
                    aiBtnText: "Generate Description by AI" , showAIBtn: true, colClass: "col-md-12" , height: "200px"
                    }) %>

                    <!-- Steps / Add More -->
                    <div class="mb-3 col-md-12">
                      <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label">Steps <span class="text-danger">*</span></label>
                        <button type="button" id="addItemBtn" class="btn btn-sm btn-outline-primary">
                          <i class="fa fa-plus"></i> Add More
                        </button>
                      </div>
                      <div id="itemContainer"></div>
                    </div>

                    <!-- Image -->
                    <div class="col-md-12">
                      <%- include("../includes/input", { label: "Project Images" , name: "images" , id: "imageInput" ,
                        type: "file" , className: "" , required: false, multiple: true }) %>

                        <small class="text-muted d-block mt-1">
                          <i class="fa-solid fa-circle-info text-primary"></i>
                          Recommended Size: <strong>554 x 500 px</strong>,
                          Formats: <strong>/jpeg|jpg|png|webp/</strong>
                        </small>

                        <div id="previewImageContainer" class="mt-2"></div>
                    </div>

                     <!-- : Section Image (Single) -->
            <div class="col-md-12 border-top pt-3">
              <label class="form-label fw-bold">Section Image (Single)</label>
              <input type="file" class="form-control" id="sectionImageInput" name="sectionImage" accept="image/*">

              <small class="text-muted d-block mt-1">
                <i class="fa-solid fa-circle-info text-primary"></i>
                Recommended Size: <strong>1460 x 420 px</strong>
              </small>

              <!-- Preview Container for Section Image -->
              <div id="sectionImagePreview" class="mt-2"></div>
            </div>

                </div>
              </form>
            </div>

            <!-- Footer -->
            <div class="modal-footer border-0 pt-0">
              <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" form="productForm" class="btn btn-primary px-4">Save</button>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../includes/allscripts') %>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <!-- Include libraries in <head> -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script src="/js/viewjs/project.js"></script>
    <script src="/js/viewjs/pagesection.js"></script>
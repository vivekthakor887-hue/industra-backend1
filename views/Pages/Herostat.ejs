<%- include('../includes/header', {admin}) %>

    <div class="body-wrapper">
        <div class="container-fluid">
            <div class="card bg-info-subtle shadow-none position-relative overflow-hidden mb-4">
                <div class="card-body px-4 py-3">
                    <div class="row align-items-center">
                        <div class="col-md-8 col-sm-7">
                            <h4 class="fw-semibold mb-1">Manage Stats</h4>
                        </div>

                        <div class="col-md-4 col-sm-5 text-md-end text-sm-start mt-3 mt-md-0">
                            <button id="addherostatBtn" class="btn btn-primary px-4">
                                <i class="fa-solid fa-plus me-2"></i> Add Stat
                            </button>
                        </div>
                    </div>
                </div>
            </div>
   <div class="datatables">
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table id="herostat_config"
                    class="table table-striped table-bordered text-nowrap align-middle">
                    <thead>
                        <tr>
                            <th>Icon</th>
                            <th>Description</th>
                            <th>Count</th>
                            <th class="action-col">Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- MODAL -->
    <div class="modal fade" id="herostatModal" tabindex="-1">
        <div class="modal-dialog modal-md modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-3">
                <div class="modal-header bg-light-subtle">
                    <h5 class="modal-title fw-semibold" id="herostatModalLabel">
                        Add Stat
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4">
           <form id="herostatForm">
  <input type="hidden" id="herostatId" name="id">

  <div class="row g-3">

      <!-- COUNT -->
    <div class="col-md-12">
      <%- include("../includes/input", {
        label: "Count",
        name: "count",
        id: "herostatCount",
        className: "form-control",
        type: "number",
        required: true
      }) %>
    </div>
    <!-- LABEL -->
    <div class="col-md-12">
      <%- include("../includes/input", {
        label: "Label",
        name: "label",
        id: "herostatLabel",
        className: "form-control",
        type: "text",
        placeholder: "Enter label",
        required: true
      }) %>
    </div>

    <!-- SHORT DESCRIPTION (TEXTAREA COMPONENT) -->
    <div class="col-md-12">
      <%- include("../includes/textarea", {
        label: "Short Description",
        name: "shortdesciption",
        id: "shortdesciption",
        placeholder: "Enter short description",
        rows: 3,
        required: false
      }) %>
    </div>

  

  </div>

  <div class="mt-4">
    <%- include("../includes/button", {
      label: "Save",
      type: "btn-primary",
      attr: 'type="submit"'
    }) %>
  </div>
</form>

                </div>

            </div>
        </div>
    </div>
</div>

        </div>
    </div>

    <%- include('../includes/allscripts') %>
        <script src="/js/viewjs/herostat.js"></script>

<div class="<%= typeof colClass !== 'undefined' ? colClass : 'col-md-12' %>">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <label class="form-label fw-medium mb-0" for="<%= id || name %>">
      <%= label || 'Description' %>
    </label>

    <% if (showAIBtn) { %>
      <button
        type="button"
        id="<%= aiBtnId || 'generateDescBtn' %>"
        class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1"
      >
        <i class="fa-solid fa-wand-magic-sparkles"></i>
        <%= aiBtnText || 'Generate Description by AI' %>
      </button>
    <% } %>
  </div>

  <div
    id="<%= editorId || 'editor' %>"
    style="height: <%= height || '150px' %>; border: 1px solid #ddd; border-radius: 6px;"
  ></div>

  <input type="hidden" id="<%= id || 'description' %>" name="<%= name || 'description' %>">
</div>
